# ═══════════════════════════════════════════════════════════════
# YojanaGPT AI - Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your API keys.
# At least ONE of these must be set. All are FREE.

# Option 1: Groq (RECOMMENDED - fastest, free at console.groq.com)
GROQ_API_KEY=

# Option 2: Google Gemini (free at aistudio.google.com/apikey)
GEMINI_API_KEY=

# Option 3: Ollama runs locally with no API key needed.
# Just install Ollama and run: ollama serve && ollama pull llama3.2

# Debug mode (set to true for verbose logging)
DEBUG=false
